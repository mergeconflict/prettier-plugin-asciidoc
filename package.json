{
  "name": "prettier-plugin-asciidoc",
  "version": "0.0.1",
  "description": "Prettier plugin for formatting AsciiDoc files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "vendor": "bash scripts/vendor.sh"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-love": "^150.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "chevrotain": "^11.1.1"
  }
}
