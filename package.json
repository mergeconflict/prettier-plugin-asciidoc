{
  "name": "prettier-plugin-asciidoc",
  "version": "0.0.1",
  "description": "Prettier plugin for formatting AsciiDoc files",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "vendor": "bash scripts/vendor.sh",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "fuzz": "FUZZ=1 vitest run tests/parser/fuzz.test.ts tests/format/fuzz.test.ts"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "eslint": "^10.0.1",
    "eslint-config-love": "^151.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "fast-check": "^4.5.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "dependencies": {
    "chevrotain": "^11.1.1"
  }
}
