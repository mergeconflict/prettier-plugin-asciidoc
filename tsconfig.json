{
  "compilerOptions": {
    "types": ["bun-types"],
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "build.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ]
}
